CONTAINER OMMDModelManager {
	NAME OMMDModelManager;
	INCLUDE Obase;

	GROUP MODEL_INFO_GRP {
		DEFAULT 1;

		REAL PMX_VERSION {
			ANIM OFF;
			UNIT REAL;
			MIN 2.0;
			STEP 0.1;
			MAX 2.1;
		}

		STRING MODEL_NAME_LOCAL {
			ANIM OFF;
		}

		STRING MODEL_NAME_UNIVERSAL {
			ANIM OFF;
		}

		STRING COMMENTS_LOCAL {
			ANIM OFF;
			CUSTOMGUI MULTISTRING;
			SCALE_H;
			SCALE_V;
		}

		STRING COMMENTS_UNIVERSAL {
			ANIM OFF;
			CUSTOMGUI MULTISTRING;
			SCALE_H;
			SCALE_V;
		}

		LONG MODEL_MODE {
			CUSTOMGUI QUICKTABRADIO;
			ANIM OFF;
			FIT_H;
			SCALE_H;

			CYCLE {
				MODEL_MODE_EDIT;
				MODEL_MODE_ANIM;
			}
		}
	}

	GROUP MODEL_ANIM_GRP {
		DEFAULT 1;

		LONG MODEL_ANIM_LIST {
			ANIM OFF;
			CYCLE {
				MODEL_ANIM_NONE;
			}
		}

		BUTTON MODEL_ANIM_LOAD_VMD_BUTTON {
			FIT_H;
			SCALE_H;
		}

		BUTTON MODEL_ANIM_DElETE_BUTTON {
			FIT_H;
			SCALE_H;
		}
	}

	GROUP MODEL_MORPH_GRP {
		GROUP MODEL_MORPH_GROUP_GRP {
			STRING MODEL_MORPH_GROUP_ADD_NAME {
				FIT_H;
				SCALE_H;
				ANIM OFF;
			}

			BUTTON MODEL_MORPH_GROUP_ADD_BUTTON {
				FIT_H;
				SCALE_H;
			}
		}

		GROUP MODEL_MORPH_FLIP_GRP {
			STRING MODEL_MORPH_FLIP_ADD_NAME {
				FIT_H;
				SCALE_H;
				ANIM OFF;
			}

			BUTTON MODEL_MORPH_FLIP_ADD_BUTTON {
				FIT_H;
				SCALE_H;
			}
		}

		GROUP MODEL_MORPH_MESH_GRP {
		}

		GROUP MODEL_MORPH_BONE_GRP {
		}
	}

	GROUP MODEL_IK_GRP {
	}
}
